# Your country — used to classify shipping as domestic / EU / international
MY_COUNTRY=Netherlands

# A listing is "a deal" when its EFFECTIVE cost is at least this fraction below
# the median effective cost of that release's same-condition pool. Effective
# cost = landed price (item + shipping, in your account currency) plus an
# estimated import-VAT uplift for non-EU origins (see VAT_RATE). 0.4 = 40% below.
DEAL_THRESHOLD=0.4

# Estimated import VAT added to the cost of NON-EU listings (UK is non-EU
# post-Brexit) so deals rank on what you'd actually pay. EU/domestic prices
# already include VAT and are left untouched. Applied uniformly across each
# condition pool, so the median comparison stays apples-to-apples. 0 disables.
VAT_RATE=0.21

# Deals at or above this effective discount get a "🔥 60%+" badge in the digest.
BIG_DEAL_THRESHOLD=0.60

# A previously-alerted listing only re-alerts when its price has since dropped
# at least this much from what we last saw. Keeps re-evaluation cheap.
PRICE_DROP_THRESHOLD=0.05

# Optional: only fetch listings from sellers above this rating (0-100).
SELLER_RATING_MIN=90

# Optional: Discogs personal access token (PAT). When set, each deal in the
# digest is annotated with the Discogs-wide median asking price for that
# condition — useful for sanity-checking deals on scarce releases where the
# in-pool median is computed over a tiny bucket. Unset = feature off; the
# watcher runs exactly as before with zero extra API calls.
#
# Token: https://www.discogs.com/settings/developers (generate PAT)
# REQUIRES seller settings on the account (currency + shipping policy) —
# https://www.discogs.com/settings/seller. No listings need to exist, but
# Discogs gates this endpoint behind a configured seller profile, which is
# personal-info-ish (address, shipping). If you'd rather not, just leave
# DISCOGS_TOKEN unset.
# DISCOGS_TOKEN=

# Optional: your Discogs username. Combined with DISCOGS_TOKEN this enables
# a "X of Y wantlist releases for sale" summary in the digest header. One
# extra PAT call per run. Skipped silently when unset.
# DISCOGS_USERNAME=

# ── Shipping hints ────────────────────────────────────────────────────────────
# When a deal fires, show the seller's shipping policy + how many more of your
# wantlist items they have, so you can combine an order. Needs DISCOGS_TOKEN
# (uses the v3 marketplace shipping-policies endpoint). One PAT call per
# deal-seller, cached persistently for SHIPPING_POLICY_TTL_DAYS.
SHIPPING_HINTS=true
# Discogs hides per-listing weight, so weight-based policies are ballparked at
# this many grams per record (record + sleeve; packaging is baked into the
# seller's tiers). Tune if the "≤N records per fee" estimate is off.
EST_GRAMS_PER_VINYL=250
# Max "also wanted from this seller" rows shown per deal (rest collapse to "+N more").
MAX_SELLER_PICKS=5
# How long a fetched shipping policy stays cached before re-fetching.
SHIPPING_POLICY_TTL_DAYS=30

# ── All-time-low signal ───────────────────────────────────────────────────────
# The watcher records the lowest landed price it observes per release+condition
# (one point per day) in state.json. When a new deal beats every prior observed
# low it earns an "⬇ all-time low" badge. PRICE_HISTORY_DAYS is the rolling
# window kept; PRICE_HISTORY_MIN_POINTS is how many observations must exist
# before the badge can fire (so it only claims a low once it's meaningful).
PRICE_HISTORY_DAYS=365
PRICE_HISTORY_MIN_POINTS=3

# Safety cap on /sell_item pagination per run. Each page is up to 100 listings;
# raise this if your wantlist regularly has more than ~3000 items for sale.
MAX_PAGES_PER_RUN=30

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# ProtonMail Bridge (headless): SMTP_HOST=127.0.0.1 SMTP_PORT=1025
# Generic STARTTLS (Fastmail, Outlook):                SMTP_PORT=587
# SSL (legacy):                                         SMTP_PORT=465
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=you@example.com
ALERT_TO=you@example.com

# ── Anti-spam / signal-quality ────────────────────────────────────────────────
DIGEST_MODE=hourly          # hourly | daily
DIGEST_HOUR_UTC=7           # used only when DIGEST_MODE=daily (7 UTC ≈ 9 CEST)
GROUP_BY_RELEASE=true        # collapse multiple sellers per release into one row
MAX_SIBLINGS_PER_RELEASE=1   # extra runner-up listings shown per release (primary + N)
MAX_DEALS_PER_EMAIL=0        # 0 = no cap (show every deal). Set a number to cap.
MAX_EMAILS_PER_DAY=4         # backstop against runaway alerting

# ── Health monitoring (optional) ──────────────────────────────────────────────
# An external URL pinged on every successful run. If pings stop, that service
# emails you that the watcher has died. https://healthchecks.io works well.
# HEALTHCHECK_URL=https://hc-ping.com/your-uuid
