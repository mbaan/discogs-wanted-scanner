# ──────────────────────────────────────────────────────────────────────────────
# discogs-wanted-scanner — configuration template
#
# Copy to `.env` and edit. EVERY uncommented var below is REQUIRED: the watcher
# aborts on startup listing anything that's unset. The commented-out vars in the
# OPTIONAL section at the bottom are feature toggles — leaving them unset just
# turns the feature off.
#
# `.env` mirrors this file key-for-key, so `diff .env .env.example` shows only
# your secrets + enabled features. Keep the two in sync when adding a knob.
# ──────────────────────────────────────────────────────────────────────────────

# Your country — classifies shipping as domestic / EU / international.
MY_COUNTRY=Germany

# ── Condition floors ──────────────────────────────────────────────────────────
# Minimum acceptable grade for the vinyl (MEDIA) and the cover (SLEEVE). Both
# must clear their floor for a listing to count. Give a short grade
# (M / NM / VG+ / VG / G+ / G / F / P) or the full Discogs string.
MIN_MEDIA_CONDITION=NM
MIN_SLEEVE_CONDITION=VG+

# ── Deal economics ────────────────────────────────────────────────────────────
# Two paths by data quality.
#
# SOLD path (>= SOLD_PRICE_MIN_POINTS recent same-condition sales): a listing is a
# deal when its ITEM price is at or below the SOLD_DEAL_PERCENTILE-th percentile of
# real sold prices — cheaper than (100 - p)% of recent buyers paid. Scale-free, so
# it self-calibrates to each release's price spread. SOLD_DEAL_MIN_DISCOUNT is a
# small materiality floor (fraction below the sold median) so trivially-tight
# markets don't alert.
SOLD_DEAL_PERCENTILE=20
SOLD_DEAL_MIN_DISCOUNT=0.05

# ASKING path (the low-confidence fallback for < SOLD_PRICE_MIN_POINTS sales): item
# price vs the same-condition asking median. Asking runs ~36% above sold
# (aspirational), so demand a steeper discount AND a minimum pool size — small pools
# produce phantom deals off an inflated median. 0.35 = 35% below.
ASKING_DATA_DEAL_THRESHOLD=0.35
ASKING_MIN_POINTS=5

# Estimated import VAT added to the cost of NON-EU listings (UK is non-EU
# post-Brexit) so deals rank on what you'd actually pay. EU/domestic prices
# already include VAT and are left untouched. Applied per-listing by shipping
# origin, so each listing's effective cost reflects what you'd actually pay
# delivered. 0 disables.
VAT_RATE=0.19

# Shipping allowance (account currency) added to the SOLD/asking median to form
# the all-in deal benchmark. A copy is a deal when its effective cost (item +
# shipping + estimated import VAT) lands at or below median + this allowance, so a
# cheap record isn't disqualified by the normal shipping every buyer pays. Set to
# 0 for a strict gate (deal only when effective cost ≤ the bare median).
# Note: for non-EU consignments ≤ €150 the seller/platform may already collect VAT
# at checkout (IOSS); the flat VAT_RATE estimate can over-count there, so we err
# toward not showing a borderline deal rather than showing a false one.
SHIPPING_ALLOWANCE=7.0

# A previously-alerted listing only re-alerts when its price has since dropped
# at least this much from what we last saw. Keeps re-evaluation cheap.
PRICE_DROP_THRESHOLD=0.05

# ── Shipping hints ────────────────────────────────────────────────────────────
# When a deal fires, show the seller's shipping policy + how many more of your
# wantlist items they have, so you can combine an order. Needs DISCOGS_TOKEN.
SHIPPING_HINTS=true
# Discogs hides per-listing weight, so weight-based policies are ballparked at
# this many grams per record (record + sleeve; packaging is baked into the
# seller's tiers). Tune if the "≤N records per fee" estimate is off.
EST_GRAMS_PER_VINYL=250
# Max "also wanted from this seller" rows shown per deal (rest collapse to "+N more").
MAX_SELLER_PICKS=5
# How long a fetched shipping policy stays cached before re-fetching.
SHIPPING_POLICY_TTL_DAYS=30

# ── Combine-shipping basket ───────────────────────────────────────────────────
# Turn the passive shipping hint into an active "add these to save €X shipping"
# recommendation: which of the seller's other wantlist items would cross their
# free-shipping threshold (or fill the current fee tier). Sub-feature of
# SHIPPING_HINTS — unset = off. Needs DISCOGS_TOKEN + SHIPPING_HINTS=true.
COMBINE_BASKET=false
# Cap on how many items a single suggestion may add (default 3 when on).
MAX_BASKET_ITEMS=3

# ── All-time-low signal ───────────────────────────────────────────────────────
# The watcher records the lowest landed price it observes per release+condition
# (one point per day) in state.db. When a new deal beats every prior observed
# low it earns an "⬇ all-time low" badge. PRICE_HISTORY_DAYS is the rolling
# window kept; PRICE_HISTORY_MIN_POINTS is how many observations must exist
# before the badge can fire (so it only claims a low once it's meaningful).
PRICE_HISTORY_DAYS=365
PRICE_HISTORY_MIN_POINTS=3

# Safety cap on /sell_item pagination per run. Each page is up to 100 listings;
# raise this if your wantlist regularly has more than ~3000 items for sale.
MAX_PAGES_PER_RUN=30

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Local SMTP bridge (headless):  SMTP_HOST=127.0.0.1 SMTP_PORT=1025
# Generic STARTTLS:                                    SMTP_PORT=587
# SSL (legacy):                                         SMTP_PORT=465
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=you@example.com
SMTP_TO=you@example.com

# ── Anti-spam / signal-quality ────────────────────────────────────────────────
# hourly | daily. daily accumulates and emails once at DIGEST_HOUR_UTC.
DIGEST_MODE=hourly
# Hour (UTC) to flush when DIGEST_MODE=daily.
DIGEST_HOUR_UTC=9
# Collapse multiple sellers per release into one row (primary + siblings).
GROUP_BY_RELEASE=true
# Extra runner-up listings shown per release (primary + N).
MAX_SIBLINGS_PER_RELEASE=1
# 0 = no cap (show every deal). Set a number to cap.
MAX_DEALS_PER_EMAIL=0
# Backstop against runaway alerting.
MAX_EMAILS_PER_DAY=10

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — leave commented to keep the feature off.
# ──────────────────────────────────────────────────────────────────────────────

# Only fetch listings from sellers above this rating (0-100).
# SELLER_RATING_MIN=90

# Discogs personal access token (PAT). When set, powers per-deal shipping hints
# (seller policy + other wantlist items from the same seller) and, with
# DISCOGS_USERNAME, the "X of Y wantlist releases" header count.
# Token: https://www.discogs.com/settings/developers — REQUIRES seller settings
# on the account (https://www.discogs.com/settings/seller).
# DISCOGS_TOKEN=

# Your Discogs username. With DISCOGS_TOKEN, enables a "X of Y wantlist releases
# for sale" summary in the digest header. One extra PAT call per run.
# DISCOGS_USERNAME=

# An external URL pinged on every successful run. If pings stop, that service
# emails you that the watcher has died. https://healthchecks.io works well.
# HEALTHCHECK_URL=https://hc-ping.com/your-uuid

# Verbose (DEBUG-level) logging for one run. Usually set inline (DEBUG=1 python
# watcher.py) rather than committed here.
# DEBUG=true

# ── Sold-price benchmark (real market value) ──────────────────────────────────
# Anchor deals to what a record *actually* sells for. Per media condition, the
# median SOLD price is scraped from the logged-in sell/history page (cookie
# session, NOT the PAT). When a condition has at least SOLD_PRICE_MIN_POINTS recent
# same-grade sales, the listing's item price is compared to the lower tail (a
# percentile) of real sold prices — cheaper than most recent buyers paid means a
# deal. Below that threshold, or with no sold data, it falls back to the
# asking-median logic (ASKING path). Fragile HTML scrape + sparse for scarce
# releases; failures degrade silently (fall back). One sell/history fetch per
# scanned release, cached for SOLD_PRICE_TTL_DAYS — the first run is heavy, then
# only new/expired releases refetch. When on, SOLD_PRICE_TTL_DAYS is required (no
# hidden default); SOLD_PRICE_MIN_POINTS is optional (defaults to 5 when unset).
# SOLD_PRICES=true
# SOLD_PRICE_TTL_DAYS=30
# SOLD_PRICE_MIN_POINTS=5
#
# Better-grade caveat: a worse grade costing less than better grades is the
# expected condition discount, but a copy priced near/above what a *better* grade
# actually sold for is a suspect deal. When a listing's effective cost is within
# SOLD_TIER_CAVEAT_GAP of (or above) the nearest *trusted* better grade's sold
# median, it keeps its place but loses the loud red rail and gets a "⚠ NM
# sells ~€X" warning. The email always shows the higher-tier sold figures so the
# gap is visible. GAP is a fraction (0.10 = 10%); MIN_POINTS is how many sales the
# better grade needs before we trust it. Both optional (defaults shown).
# SOLD_TIER_CAVEAT_GAP=0.10
# SOLD_TIER_CAVEAT_MIN_POINTS=3
#
# Live competitive picture (LIVE_MARKET). For each *alerting* release, scrape the
# logged-in /sell/release page (cookie session, NOT the PAT) to get every copy
# currently for sale, so each deal shows the single best OTHER offer (win or lose)
# and a "rest of the field" ladder — the email becomes the "is this really the
# cheapest?" check so you don't open Discogs to verify. When a cheaper copy exists
# it fires the oxblood "Best price" card; when you're already cheapest it shows a
# neutral "Next best" runner-up plus a "✓ Cheapest of N" chip. Copies below your
# condition floor are shown but tagged so they can't pose as alternatives. Live
# listings can't be cached (they change), so this is one request per alerting
# release — bounded by LIVE_MARKET_MAX_PER_RUN. Fragile HTML scrape; a miss
# degrades to "cheapest I can see" (no absolute claim). Needs cookies.
# LIVE_MARKET=true
# LIVE_MARKET_MAX_PER_RUN=25
#
# Optional: redirect the static HTML report (default: ./report.html). Unset =
# default path; the report is always written each run (cheap, Pi-safe).
# REPORT_HTML=/var/www/discogs/report.html
#
# ── Real-time push fast-lane (ntfy) ───────────────────────────────────────────
# Route TOP-TIER deals to an instant phone push (ntfy.sh app) so rare finds aren't
# buried until the next email. ADDITIVE: pushed deals still appear in the digest.
# Fires on the same cron run that detects the deal — beats the email by the digest
# interval, not by minutes (tighten the cron for truly faster). Needs the free
# ntfy app subscribed to your NTFY_TOPIC. When PUSH_ENABLED, NTFY_TOPIC is required.
# PUSH_ENABLED=true
# PUSH_CHANNEL=ntfy
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOPIC=                 # pick an unguessable string, e.g. 4Tz9-Qp2xK-7mWr
# NTFY_TOKEN=                 # only for protected / self-hosted topics
# PUSH_MIN_DISCOUNT=0.30      # min discount fraction for a non-all-time-low deal
# PUSH_PRIORITY=high          # 1..5 or min|low|default|high|max
# PUSH_MAX_PER_RUN=10
